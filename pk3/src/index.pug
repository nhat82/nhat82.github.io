doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title RaR Compass Calibration (Debug Mode)
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap", rel="stylesheet")
    style.
      body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background-color: #000;
        color: #fff;
        text-align: center;
        padding: 1.5rem;
      }

      header {
        margin-bottom: 2rem;
      }

      #compass-wrapper {
        position: relative;
        width: 300px;
        height: 300px;
        margin: 2rem auto;
      }

      #heading-value {
        font-size: 1.3rem;
        margin-top: 1rem;
      }

      button {
        display: block;
        width: 90%;
        max-width: 300px;
        margin: 1rem auto;
        padding: 1rem;
        font-size: 1rem;
        border-radius: 8px;
        border: 2px solid white;
        background: transparent;
        color: white;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      button:hover {
        background: white;
        color: black;
      }

      footer {
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #aaa;
      }

      #debug-info {
        background: rgba(255, 255, 255, 0.8);
        color: #000;
        font-size: 0.9rem;
        padding: 1rem;
        text-align: left;
        max-height: 150px;
        overflow-y: auto;
        margin-top: 1rem;
      }

  body
    header
      .title
        span(style="color: #f23c3c; font-size: 1.5rem; font-weight:700;") Roots
        span(style="color: #fff; font-size: 1.5rem; font-weight:700;") and
        span(style="color: #f5cc3b; font-size: 1.5rem; font-weight:700;") Routes

    h2 🧭 Calibrate Your Heading
    p Face true North, then tap "Calibrate" to begin the AR experience.

    p#heading-value Heading: ...

    button#start-btn Start Compass
    button#calibrate-btn Calibrate & Enter AR

    div#debug-info Debug Info:

    footer
      Plants Team © 2024

    script(src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js")
    script.
      // Debug logging function
      function logDebug(message) {
        const debugInfo = document.getElementById("debug-info");
        debugInfo.innerHTML += `<br>${message}`;
      }

      document.addEventListener("DOMContentLoaded", () => {
        logDebug("DOM fully loaded.");

        // Detect if user is on iOS
        const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);
        logDebug("isIOS: " + isIOS);

        // If not iOS, redirect to ar.html immediately
        if (!isIOS) {
          logDebug("Non-iOS detected. Redirecting to ar.html.");
          window.location.href = "ar.html";
          return;
        }

        // Initialize Three.js Scene
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer();
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        let currentHeading = 0;
        let calibrationOffset = 0;

        // Add a simple cube to the scene as a reference (could represent something in AR)
        const geometry = new THREE.BoxGeometry(1, 1, 1);
        const material = new THREE.MeshBasicMaterial({ color: 0x00ff00 });
        const cube = new THREE.Mesh(geometry, material);
        scene.add(cube);
        camera.position.z = 5;

        // Handle device orientation events
        function handleOrientation(event) {
          const heading = event.webkitCompassHeading || (360 - event.alpha);
          logDebug("Orientation event received. Heading: " + heading);

          if (heading !== undefined && !isNaN(heading)) {
            currentHeading = heading;

            // Update heading display
            const headingDisplay = document.getElementById("heading-value");
            headingDisplay.textContent = `Heading: ${Math.round(heading)}°`;

            // Adjust the camera's rotation (calibrated with the offset)
            camera.rotation.y = -(heading + calibrationOffset) * (Math.PI / 180);
          }
        }

        // Start compass functionality
        function startCompass() {
          logDebug("startCompass triggered.");
          if (typeof DeviceOrientationEvent.requestPermission === "function") {
            DeviceOrientationEvent.requestPermission()
              .then(permission => {
                logDebug("Compass permission: " + permission);
                if (permission === "granted") {
                  window.addEventListener("deviceorientation", handleOrientation, true);
                  logDebug("Added deviceorientation event listener.");
                } else {
                  alert("Compass access denied.");
                }
              })
              .catch(err => {
                alert("Compass not supported.");
                logDebug("Error: " + err);
              });
          } else {
            // Fallback for non-iOS devices (shouldn't happen on iOS)
            window.addEventListener("deviceorientation", handleOrientation, true);
            logDebug("Added fallback orientation event listeners.");
          }
        }

        // Calibrate function
        document.getElementById("calibrate-btn").addEventListener("click", () => {
          calibrationOffset = (360 - currentHeading + 360) % 360;
          logDebug("Calibration offset calculated: " + calibrationOffset);
          localStorage.setItem("calibrationOffset", calibrationOffset);
          logDebug("Stored calibration offset. Redirecting to AR.");
          window.location.href = "ar.html";  // Redirect to the AR experience
        });

        // Start the compass when the user clicks "Start Compass"
        document.getElementById("start-btn").addEventListener("click", startCompass);

        // Animation loop to render the scene
        function animate() {
          requestAnimationFrame(animate);
          renderer.render(scene, camera);
        }
        animate();
      });
    </script>
